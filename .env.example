# ==============================================================================
# SafeX AI Knowledge Assistant - Environment Configuration Template
# Rename this file to '.env' and fill in your values.
# DO NOT commit the actual '.env' file containing secrets to version control.
# ==============================================================================

# Google Gemini API Key (Obtain from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Application Configuration
ENV_MODE=development # development, testing, production
LOG_LEVEL=INFO       # DEBUG, INFO, WARNING, ERROR, CRITICAL

# RAG Pipeline Configuration Paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
VECTOR_STORE_DIR=data/vector_store
